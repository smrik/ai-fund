# Local secrets for Alpha Pod
# Copy this file to `.env` and fill in only what you use.

# OpenAI-compatible LLM provider
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Gemini OpenAI-compatible path
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Optional research / macro providers
PERPLEXITY_API_KEY=
FRED_API_KEY=

# Optional runtime overrides
LLM_MODEL=gemini-3-flash-preview
LLM_MODEL_FAST=gemini-3-flash-preview
LLM_SYNTHESIS_MODEL=gemini-3-flash-preview
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
EDGAR_USER_AGENT=AI-Fund research@example.com
