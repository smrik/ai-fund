# Local secrets for Alpha Pod
# Copy this file to `.env` and fill in only what you use.

# OpenAI-compatible LLM provider
OPENAI_API_KEY=
OPENAI_BASE_URL=

# OpenRouter OpenAI-compatible path for low/no-cost live agent testing.
# `openrouter/free` lets OpenRouter choose an available free model.
OPENROUTER_API_KEY=
OPENROUTER_FREE_MODEL=openrouter/free

# Gemini OpenAI-compatible path
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Optional research / macro providers
PERPLEXITY_API_KEY=
FRED_API_KEY=

# Optional runtime overrides
LLM_MODEL=gemini-3-flash-preview
LLM_MODEL_FAST=gemini-3-flash-preview
LLM_SYNTHESIS_MODEL=gemini-3-flash-preview
INDUSTRY_AGENT_MODEL=gemini-3-flash-preview
# For OpenRouter testing, set LLM_BASE_URL=https://openrouter.ai/api/v1 and set
# LLM_MODEL / agent model env vars to a :free model ID.
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
EDGAR_USER_AGENT=AI-Fund research@example.com
EDGAR_LOCAL_DATA_DIR=data/cache/edgar_tools
ALPHA_POD_EDGAR_CACHE_ONLY=0
ALPHA_POD_MARKET_CACHE_ONLY=0
ALPHA_POD_ALLOW_STALE_MARKET_CACHE=0
ALPHA_POD_DB_PATH=
