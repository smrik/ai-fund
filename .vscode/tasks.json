{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Docs: MkDocs Serve",
      "type": "shell",
      "command": "ca ai-fund && python -m mkdocs serve",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Docs: MkDocs Build Strict",
      "type": "shell",
      "command": "ca ai-fund && python -m mkdocs build --strict",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Quality: Local Gate",
      "type": "shell",
      "command": "ca ai-fund && python scripts/dev/run_local_quality_gate.py",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
